# KubeSwift sandbox kernel profile — Linux config fragment.
# Buildroot expands this via olddefconfig (unset symbols take their defaults).
# Base = faas-minimal (direct-kernel microVM: virtio-blk/net/console, ext4,
# serial, KVM guest). The sandbox profile adds what the OCI-rootfs sandbox
# runtime needs and what faas-minimal deliberately trims for a real userspace.
#
# Validated by the OCI-rootfs spike: faas-minimal lacks OVERLAY_FS/VIRTIO_FS/
# VSOCK; a kernel with them (Kata 6.12) boots the RO-base+overlay and
# virtio-fs-as-root models. This config puts those on the 6.6 LTS faas base.

# --- base (faas-minimal) ---
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=128
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_EXT4_FS=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_MODULES=n
CONFIG_DEBUG_KERNEL=n
CONFIG_SWAP=n
CONFIG_INOTIFY_USER=y

# --- sandbox additions ---

# Overlay root: read-only OCI base (lowerdir) + tmpfs upper. The bridge-initramfs
# mounts the OCI image RO and layers a tmpfs so the signed image is never mutated.
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

# virtio-fs shared-tree rootfs (density option — one host tree, many sandboxes).
# Requires FUSE. DAX left off (perf-only; the spike ran virtio-fs without it).
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# vsock control channel — exec/attach and the in-guest agent instead of SSH.
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# seccomp syscall filtering for untrusted workloads.
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# cgroup v2 resource control (a sandbox may run a container-shaped workload).
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_PIDS=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_SCHED=y

# namespaces — isolation; enough to nest a container runtime inside the sandbox.
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y

# Real-userspace essentials that faas-minimal trims (a stock OCI image needs them).
CONFIG_SYSVIPC=y
CONFIG_UNIX98_PTYS=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_FHANDLE=y
CONFIG_FUTEX=y
CONFIG_MULTIUSER=y
