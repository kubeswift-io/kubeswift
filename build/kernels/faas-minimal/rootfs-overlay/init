#!/bin/sh
# KubeSwift faas-minimal /init
# Minimal init: mount required filesystems, set up networking, drop to shell

set -e

# Mount required virtual filesystems
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev 2>/dev/null || mount -t tmpfs none /dev

# Create essential /dev nodes if devtmpfs unavailable
mkdir -p /dev/pts
mount -t devpts none /dev/pts 2>/dev/null || true

# Bring up loopback
ip link set lo up 2>/dev/null || true

# Announce boot complete on serial console
echo ""
echo "KubeSwift faas-minimal ready"
echo "kernel: $(uname -r)"
echo ""

# Drop to interactive shell
# In production: exec workload binary here instead
exec /bin/sh