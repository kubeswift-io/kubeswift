BR2_PACKAGE_BUSYBOX=y
BR2_ROOTFS_INIT_BUSYBOX=y
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL)/rootfs-overlay"
BR2_TARGET_GENERIC_HOSTNAME="faas"
