# Multi-stage build for swiftletd + Cloud Hypervisor
# Build swiftletd
FROM rust:1-bookworm AS builder
WORKDIR /build

ARG VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

# Copy workspace
COPY Cargo.toml Cargo.lock ./
COPY swiftletd ./swiftletd
COPY swift-runtime ./swift-runtime
COPY swift-seed ./swift-seed
COPY swift-ch-client ./swift-ch-client

RUN KUBESWIFT_VERSION=$VERSION KUBESWIFT_GIT_COMMIT=$GIT_COMMIT KUBESWIFT_BUILD_DATE=$BUILD_DATE \
    cargo build -p swiftletd --release

# Runtime stage
FROM debian:bookworm-slim
ARG VERSION=dev
ARG GIT_COMMIT=unknown
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${GIT_COMMIT}"
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    genisoimage \
    socat \
    iproute2 \
    iptables \
    bridge-utils \
    dnsmasq \
    procps \
    openssh-client \
    bash \
    bash-completion \
    dnsutils \
    && rm -rf /var/lib/apt/lists/*

# Cloud Hypervisor static binary (v51.1)
ARG CH_VERSION=51.1
ARG TARGETARCH=amd64
RUN CH_ARCH=$(echo "${TARGETARCH}" | sed 's/amd64//;s/arm64/-aarch64/') && \
    curl -sSL -o /usr/local/bin/cloud-hypervisor \
    "https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/v${CH_VERSION}/cloud-hypervisor-static${CH_ARCH}" && \
    chmod +x /usr/local/bin/cloud-hypervisor

# Rust Hypervisor Firmware for disk boot (required for serial device creation)
# CH needs --kernel (firmware) to properly initialize VM and create serial socket
ARG RHF_VERSION=0.5.0
RUN mkdir -p /usr/share/kubeswift-firmware && \
    if [ "${TARGETARCH}" = "amd64" ]; then \
        curl -sSL -o /usr/share/kubeswift-firmware/hypervisor-fw \
        "https://github.com/cloud-hypervisor/rust-hypervisor-firmware/releases/download/${RHF_VERSION}/hypervisor-fw"; \
    elif [ "${TARGETARCH}" = "arm64" ]; then \
        curl -sSL -o /usr/share/kubeswift-firmware/hypervisor-fw \
        "https://github.com/cloud-hypervisor/rust-hypervisor-firmware/releases/download/${RHF_VERSION}/hypervisor-fw-aarch64"; \
    fi && \
    chmod 644 /usr/share/kubeswift-firmware/hypervisor-fw

COPY --from=builder /build/target/release/swiftletd /usr/local/bin/swiftletd
COPY swiftletd/scripts/network-init.sh /usr/local/bin/network-init.sh
COPY swiftletd/scripts/launcher-entrypoint.sh /usr/local/bin/launcher-entrypoint.sh
RUN chmod +x /usr/local/bin/network-init.sh /usr/local/bin/launcher-entrypoint.sh

# Runtime paths (must match internal/controller/swiftguest constants)
ENV KUBESWIFT_RUN_DIR=/var/lib/kubeswift/run
# Intent path default
ENV KUBESWIFT_INTENT_PATH=/var/lib/kubeswift/intent/runtime-intent.json

ENTRYPOINT ["/usr/local/bin/launcher-entrypoint.sh"]
