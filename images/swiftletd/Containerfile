# Multi-stage build for swiftletd + Cloud Hypervisor.
#
# Build context is the repo root (the Makefile passes `.`). This lets
# us build both the Rust launcher (under rust/) and the small Go
# snapshot-stager init-container helper (under cmd/snapshot-stager,
# which depends on internal/snapshot/configjson) from the same image.
FROM rust:1-bookworm AS builder
WORKDIR /build

ARG VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

# Copy the Rust workspace from the rust/ subtree of the repo.
COPY rust/Cargo.toml rust/Cargo.lock ./
COPY rust/swiftletd ./swiftletd
COPY rust/swift-runtime ./swift-runtime
COPY rust/swift-seed ./swift-seed
COPY rust/swift-ch-client ./swift-ch-client
COPY rust/swift-qemu-client ./swift-qemu-client

RUN KUBESWIFT_VERSION=$VERSION KUBESWIFT_GIT_COMMIT=$GIT_COMMIT KUBESWIFT_BUILD_DATE=$BUILD_DATE \
    cargo build -p swiftletd --release

# Build snapshot-stager (Go init-container helper) from the same
# repo-root context. snapshot-stager imports
# internal/snapshot/configjson — the source-of-truth for the narrow
# config.json edits applied to a Tier B clone (see commits 12/13).
FROM golang:1.25-bookworm AS go-builder
WORKDIR /go-build
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
COPY api ./api
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/snapshot-stager ./cmd/snapshot-stager

# Runtime stage
FROM debian:bookworm-slim
ARG VERSION=dev
ARG GIT_COMMIT=unknown
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${GIT_COMMIT}"
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    genisoimage \
    socat \
    iproute2 \
    iptables \
    bridge-utils \
    dnsmasq \
    procps \
    openssh-client \
    bash \
    bash-completion \
    dnsutils \
    qemu-system-x86 \
    ovmf \
    && rm -rf /var/lib/apt/lists/*

# ovmf package installs to /usr/share/OVMF/OVMF_CODE.fd and /usr/share/OVMF/OVMF_VARS.fd
# qemu-system-x86 package provides /usr/bin/qemu-system-x86_64
# Both paths are the defaults in swift-qemu-client/src/config.rs

# Cloud Hypervisor static binary (v52.0)
# Bumped v51.1 -> v52.0: v51.1's virtio-blk has a bug that bugchecks Windows'
# viostor driver (0xD1); v52.0 fixes it and boots Windows cleanly. See
# docs/design/windows-guest-support-spike.md sec 4.1. The CLOUDHV.fd firmware
# below (ch-13b4963ec4) is the spike-validated pairing with the v52.0 binary.
ARG CH_VERSION=52.0
ARG TARGETARCH=amd64
RUN CH_ARCH=$(echo "${TARGETARCH}" | sed 's/amd64//;s/arm64/-aarch64/') && \
    curl -sSL -o /usr/local/bin/cloud-hypervisor \
    "https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/v${CH_VERSION}/cloud-hypervisor-static${CH_ARCH}" && \
    chmod +x /usr/local/bin/cloud-hypervisor

# CLOUDHV.fd — Cloud Hypervisor UEFI firmware (EDK2/OVMF build for CH)
# Passed via --kernel flag for disk boot. Supports all modern Linux distributions.
# Pin to a specific release for reproducibility.
ARG CLOUDHV_TAG=ch-13b4963ec4
ARG CLOUDHV_SHA256=f46ebc32e6b32fb58b83e10e9bf89df5ea7f103b4f8fc3999b6557b513d62b4e
RUN mkdir -p /usr/share/kubeswift-firmware && \
    curl -sSL -o /usr/share/kubeswift-firmware/CLOUDHV.fd \
    "https://github.com/cloud-hypervisor/edk2/releases/download/${CLOUDHV_TAG}/CLOUDHV.fd" && \
    echo "${CLOUDHV_SHA256}  /usr/share/kubeswift-firmware/CLOUDHV.fd" | sha256sum -c - && \
    chmod 644 /usr/share/kubeswift-firmware/CLOUDHV.fd

COPY --from=builder /build/target/release/swiftletd /usr/local/bin/swiftletd
COPY --from=go-builder /out/snapshot-stager /usr/local/bin/snapshot-stager
COPY rust/swiftletd/scripts/network-init.sh /usr/local/bin/network-init.sh
COPY rust/swiftletd/scripts/launcher-entrypoint.sh /usr/local/bin/launcher-entrypoint.sh
COPY rust/swiftletd/scripts/gpu-init.sh /usr/local/bin/gpu-init.sh
RUN chmod +x /usr/local/bin/network-init.sh /usr/local/bin/launcher-entrypoint.sh /usr/local/bin/gpu-init.sh

# Runtime paths (must match internal/controller/swiftguest constants)
ENV KUBESWIFT_RUN_DIR=/var/lib/kubeswift/run
# Intent path default
ENV KUBESWIFT_INTENT_PATH=/var/lib/kubeswift/intent/runtime-intent.json

ENTRYPOINT ["/bin/sh", "/usr/local/bin/launcher-entrypoint.sh"]
