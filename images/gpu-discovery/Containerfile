# Multi-stage build for gpu-discovery
FROM golang:1.25-bookworm AS builder
WORKDIR /build

ARG VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

# Copy module files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source
COPY . .

# Build gpu-discovery with version stamping
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags "-X github.com/projectbeskar/kubeswift/internal/version.Version=${VERSION} -X github.com/projectbeskar/kubeswift/internal/version.GitCommit=${GIT_COMMIT} -X github.com/projectbeskar/kubeswift/internal/version.BuildDate=${BUILD_DATE}" \
    -o gpu-discovery ./cmd/gpu-discovery

# Runtime stage — needs pciutils (lspci) and util-linux (lscpu)
FROM debian:bookworm-slim
ARG VERSION=dev
ARG GIT_COMMIT=unknown
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.revision="${GIT_COMMIT}"
RUN apt-get update && apt-get install -y --no-install-recommends \
    pciutils \
    && rm -rf /var/lib/apt/lists/*
# lscpu is part of util-linux which is included in bookworm-slim by default.
COPY --from=builder /build/gpu-discovery /gpu-discovery
USER 65534:65534
ENTRYPOINT ["/gpu-discovery"]
